{
  "name": "scpn-mif-core-studio-web",
  "version": "0.1.1",
  "private": true,
  "description": "The SCPN-MIF-CORE MIF Studio UI remote — a Module Federation 2.x remote exposing the MifStudioPanel the SCPN Studio Hub federates at runtime.",
  "license": "AGPL-3.0-or-later",
  "author": "Miroslav Šotek <protoscience@anulum.li>",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"test/**/*.{ts,tsx}\"",
    "test": "vitest run"
  },
  "dependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@module-federation/vite": "1.16.12",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "10.5.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "jsdom": "29.1.1",
    "prettier": "3.9.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vite": "8.1.4",
    "vitest": "4.1.9"
  }
