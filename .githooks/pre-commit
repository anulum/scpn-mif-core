#!/usr/bin/env bash
# SPDX-License-Identifier: AGPL-3.0-or-later
# SCPN-MIF-CORE — pre-commit hook for fast local quality checks.
set -euo pipefail

# Workspace-location guard (Samsung GOTM ext4 + no symlinks).
python tools/check_samsung_workspace.py

# Sync-state tag linter (~ <1s).
python tools/check_sync_tags.py --root .

# Secret-pattern scan on the staged diff (~ <1s).
python tools/check_secrets.py

# Authorship-line preview (advisory; enforced again in preflight).
if [ -z "$(git diff --cached --name-only)" ]; then
    exit 0
fi
echo "pre-commit: sync + secrets clean; reminder to add 'Authored by Anulum Fortis & Arcane Sapience (protoscience@anulum.li)' to the commit message."
