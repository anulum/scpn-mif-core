        "inputs": [
          "lock verdict",
          "safety certificate",
          "bank feasibility"
        ],
        "outputs": [
          "MergeTriggerReport: FIRE / ABORT_UNSAFE / HOLD_NO_LOCK / ABORT_BANK_INFEASIBLE"
        ],
        "processing_model": "instability-preemption gate over the composed kernels",
        "stage": "decision"
